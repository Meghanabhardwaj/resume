\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{formatting}[2026/03/07 Resume formatting helpers]

\RequirePackage[dvipsnames]{xcolor}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{enumitem}
\RequirePackage{moresize}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{hyperxmp}
\RequirePackage{titlesec}
\RequirePackage{XCharter}
\RequirePackage{xstring}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{etoolbox}
\RequirePackage{microtype}
\RequirePackage{datetime2}
\RequirePackage{embedfile}

\geometry{
  letterpaper,
  top=0.3in,
  bottom=0.2in,
  left=0.3in,
  right=0.3in
}

\raggedright
\pagestyle{empty}
\input{glyphtounicode}
\pdfgentounicode=1

% PDF/UA - mark document as tagged for accessibility
\pdfminorversion=7
\pdfobjcompresslevel=0

\titleformat{\section}
  {\bfseries\large\color{RoyalBlue}}{}{}{}[\vspace{1pt}\titlerule\vspace{-6.5pt}]

\renewcommand\labelitemi{$\vcenter{\hbox{\small$\bullet$}}$}
\setlist[itemize]{
  itemsep=-2pt,
  leftmargin=12pt,
  topsep=7pt
}

\setlength{\parskip}{0pt}
\setlength{\parindent}{0pt}

\newcommand{\sectionspace}[1]{\vspace{#1}}
\newcommand{\entryspace}{\vspace{-7pt}}
\newcommand{\projectspace}{\vspace{-9pt}}
\newcommand{\resumesection}[1]{\section*{#1}}

\newcommand{\resumeName}[1]{\centerline{\Huge #1}}
\newcommand{\resumeContactLine}[1]{\vspace{5pt}\centerline{#1}}
\newcommand{\resumeProfileLinks}[1]{%
  \vspace{5pt}%
  \centerline{\color{RoyalBlue}#1}%
}

\newcommand{\educationentry}[3]{%
  \noindent\makebox[\linewidth][l]{\textbf{#1} -- #2\hfill #3}%
}

\newcommand{\experiencecompany}[2]{%
  \noindent\makebox[\linewidth][l]{\textbf{#1}\hfill #2}\par
}

\newcommand{\experiencerole}[2]{%
  \noindent\makebox[\linewidth][l]{\textit{#1}\hfill #2}%
}

\newcommand{\experienceentry}[4]{%
  \experiencecompany{#1}{#2}
  \experiencerole{#3}{#4}
  \entryspace
  \begin{itemize}
}

\newcommand{\experienceentryend}{%
  \end{itemize}
}

\newcommand{\projectheading}[4]{%
  \noindent\makebox[\linewidth][l]{{\textbf{#1}, #2}\hfill \href{#3}{\color{RoyalBlue}{#4}}}\par
}

\newcommand{\projectentry}[4]{%
  \projectheading{#1}{#2}{#3}{#4}
  \projectspace
  \begin{itemize}
}

\newcommand{\projectentryend}{%
  \end{itemize}
}

\newcommand{\shorturl}[1]{%
  \StrSubstitute{#1}{https://}{}[\Result]%
  \StrSubstitute{\Result}{http://}{}[\Result]%
  \StrSubstitute{\Result}{mailto:}{}[\Result]%
  \href{#1}{\Result}%
}

\newcommand{\projectlink}[2]{\href{#1}{\color{RoyalBlue}{#2}}}
\newcommand{\skillline}[2]{\textbf{#1:} #2 \\}
